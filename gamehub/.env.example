# GameHub frontend environment variables
# In this GitHub Pages build the app runs on an in-memory mock backend, so none
# of these are required to run locally. They document the production wiring.

# Base URL of the GameHub API gateway
VITE_API_URL=https://api.gamehub.example.com

# WebSocket / realtime gateway
VITE_WS_URL=wss://realtime.gamehub.example.com

# OAuth client IDs (public values; secrets live only on the backend)
VITE_GOOGLE_CLIENT_ID=
VITE_DISCORD_CLIENT_ID=

# Public CDN base for media (clips, avatars, banners)
VITE_CDN_URL=https://cdn.gamehub.example.com

# Set to "mock" to force the in-memory data layer (default in this build)
VITE_DATA_SOURCE=mock
